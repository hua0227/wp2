* TEST AND FIX CHOLESTEROL RING PENERTRATION
*

DIMENS CHSIZE 5000000 MAXRES 3000000

! Read topology and parameter files
stream toppar.str

! Read the system information
stream step3_size.str
stream step4_components.str


! Read Lipids
open read unit 10 card name step4_lipid_lipid.psf
read psf  unit 10 card append

open read unit 10 card name step4_lipid_lipid.crd
read coor unit 10 card append

!
! Image Setup
!

open read unit 10 card name crystal_image.str
CRYSTAL DEFINE @XTLtype @A @B @C @alpha @beta @gamma
CRYSTAL READ UNIT 10 CARD

!Image centering by residue
IMAGE BYRESID XCEN 0.0 YCEN 0.0 ZCEN @zcen sele resname TIP3 .or. segid MEMB end

!
! Nonbonded Options
!

nbonds atom vatom vfswitch bycb -
       ctonnb 6.0 ctofnb 7.0 cutnb 10.0 cutim 10.0 -
       inbfrq -1 imgfrq -1 wmin 1.0 cdie eps 1.0 
energy

!
! Remove the cholesterol ring penetration problem:
! (1) translate along Z 
! (2) slow bring it back to the original Z by relaxing neighboring lipid molecules
!
set resi 108

define fixchol sele resi @resi .and. segid MEMB end
coor stat sele fixchol end

! define the flexible region
calc xmax1 = ?xave + 8
calc xmin1 = ?xave - 8
calc ymax1 = ?yave + 8
calc ymin1 = ?yave - 8

calc xbox = @A / 2.0
calc ybox = @B / 2.0

calc xmax2 = @xmax1
calc xmin2 = @xmin1
calc ymax2 = @ymax1
calc ymin2 = @ymin1

if xmax1 .gt.  @xbox then
   calc xmax2 =  @xmax1 - @A
   calc xmax1 =  @xbox
   calc xmin2 = -@xbox
endif
if xmin1 .lt. -@xbox then
   calc xmin2 =  @xmin1 + @A
   calc xmin1 = -@Xbox
   calc xmax2 =  @Xbox
endif
if ymax1 .gt.  @ybox then
   calc ymax2 =  @ymax1 - @B
   calc ymax1 =  @ybox
   calc ymin2 = -@ybox
endif
if ymin1 .lt. -@ybox then
   calc ymin2 =  @ymin1 + @B
   calc ymin1 = -@ybox
   calc ymax2 =  @ybox
endif

if xmax1 .eq. @xmax2 if ymax1 .eq. @ymax2 -
   define flexible sele .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) end

if xmax1 .eq. @xmax2 if ymax1 .ne. @ymax2 -
   define flexible sele .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) .or. -
                        .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin2 ) .and. ( prop Y .lt. @ymax2 ) ) end

if xmax1 .ne. @xmax2 if ymax1 .eq. @ymax2 -
   define flexible sele .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) .or. -
                        .byres. ( ( prop X .gt. @xmin2 ) .and. ( prop X .lt. @xmax2 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) end

if xmax1 .ne. @xmax2 if ymax1 .ne. @ymax2 -
   define flexible sele .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) .or. -
                        .byres. ( ( prop X .gt. @xmin2 ) .and. ( prop X .lt. @xmax2 ) .and. ( prop Y .gt. @ymin1 ) .and. ( prop Y .lt. @ymax1 ) ) .or. -
                        .byres. ( ( prop X .gt. @xmin1 ) .and. ( prop X .lt. @xmax1 ) .and. ( prop Y .gt. @ymin2 ) .and. ( prop Y .lt. @ymax2 ) ) .or. -
                        .byres. ( ( prop X .gt. @xmin2 ) .and. ( prop X .lt. @xmax2 ) .and. ( prop Y .gt. @ymin2 ) .and. ( prop Y .lt. @ymax2 ) ) end

! Sterol movement direction

if ?zave .gt. 0 then
   calc ztran =  15
   calc zstep =  -1
endif

if ?zave .lt. 0 then
   calc ztran = -15
   calc zstep =   1
endif

coor trans zdir @ztran sele fixchol end

set zadju 0

label domin

   coor stat sele fixchol end
   coor trans zdir @zstep sele fixchol end
   coor stat sele fixchol end
   cons fix  sele fixchol end 

   if ztran .gt. 0 cons fix sele .not. ( flexible .and. prop Z .gt. 0 ) end
   if ztran .lt. 0 cons fix sele .not. ( flexible .and. prop Z .lt. 0 ) end

   mini sd   nstep 50
   mini abnr nstep 50

   cons fix  sele none end

incr zadju by 1
if zadju .le. 15 goto domin

define MEMB sele segid MEMB end
define NONMEMB sele .not. MEMB end
if ?nsel .gt. 0 delete atom sele NONMEMB end

open write unit 10 card name step4_lipid_lipid.crd
write coor unit 10 card
close unit 10

stop
